# IBM Cloud API Key (required)
IBM_API_KEY=99AB-ehSCmPbSzJ4dA4ghKLcZRMuArHdu8XlKiB9CQCJ

# IBM Watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=d00d4e28-8424-4d3d-85a3-008b9c213001

# IBM Watsonx.ai URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite Model ID (default: granite-13b-instruct-v2)
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# Flask secret key (change this to a random string in production)
FLASK_SECRET_KEY=change-me-to-a-random-secret-key

# Flask debug mode (set to False in production)
FLASK_DEBUG=True

# Port (default: 5000)
PORT=5000
